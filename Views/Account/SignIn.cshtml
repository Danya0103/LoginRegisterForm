@model LoginRegisterForm.ViewModels.LoginViewModel

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}

<h1>Sign in</h1>

<br>
<form asp-action="SignInMethod" method="post">
    
    @Html.AntiForgeryToken()
    
    
    <input asp-for="Login" type="text" class="input-data" placeholder="Enter your Login\Email">
    @* <span asp-validation-for="Login" class="text-danger"></span>*@<br> 

    <input asp-for="Password" type="password" class="input-data" placeholder="Enter your password">
    @* <span asp-validation-for="Password" class="text-danger"></span>*@<br> 
    <div asp-validation-summary="All" class="text-danger"></div>
    <button type="submit" class="btn-login">Login</button><br>

</form>

Sign up now <a asp-action="SignUp">Sign Up</a><br>

<p class="">---------- Other ways to sign in ----------</p><br>

<button class="btn-other">Google</button> <button class="btn-other">Apple</button> <button class="btn-other">Facebook</button> <button class="btn-other">X</button><br>